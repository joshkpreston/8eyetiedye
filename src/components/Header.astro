---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/generate", label: "Create" },
  { href: "/gallery", label: "Gallery" },
  { href: "/about", label: "About" },
  { href: "/faq", label: "FAQ" },
];

const currentPath = Astro.url.pathname;
---

<header
  class="fixed top-0 left-0 right-0 z-50 bg-surface-900/80 backdrop-blur-md border-b border-white/5"
>
  <nav class="container mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="text-2xl">🕷️</span>
      <span
        class="font-display font-bold text-lg dye-gradient-text group-hover:opacity-80 transition-opacity"
      >
        8EyeTieDye
      </span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-6">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "font-medium text-sm transition-colors",
                currentPath === link.href
                  ? "text-dye-pink"
                  : "text-gray-400 hover:text-white",
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <a
      href="/generate"
      class="hidden md:inline-block px-5 py-2 bg-dye-purple hover:bg-dye-purple-dark text-white text-sm font-semibold rounded-lg transition-all hover:scale-105"
    >
      Spin the Web
    </a>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-gray-400 hover:text-white"
      aria-label="Toggle menu"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-surface-800 border-b border-white/5"
  >
    <ul class="container mx-auto px-4 py-4 space-y-3">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "block py-2 font-medium transition-colors",
                currentPath === link.href
                  ? "text-dye-pink"
                  : "text-gray-400 hover:text-white",
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="pt-2">
        <a
          href="/generate"
          class="block text-center px-5 py-3 bg-dye-purple hover:bg-dye-purple-dark text-white font-semibold rounded-lg transition-all"
        >
          Spin the Web
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
