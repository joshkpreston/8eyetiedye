---
const currentYear = new Date().getFullYear();
---

<footer class="bg-surface-800 border-t border-white/5 mt-auto">
  <div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2 mb-3">
          <img src="/spider.svg" alt="Doobie" class="w-8 h-8" />
          <span class="font-display font-bold text-lg dye-gradient-text"
            >8EyeTieDye</span
          >
        </a>
        <p class="text-gray-500 text-sm">
          AI-generated tie-dye designs. Every pattern is unique, never repeated.
          Spun just for you.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="font-display font-semibold text-sm text-gray-300 mb-3">
          Links
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="/generate"
              class="text-gray-500 hover:text-white transition-colors"
              >Create a Design</a
            >
          </li>
          <li>
            <a
              href="/gallery"
              class="text-gray-500 hover:text-white transition-colors"
              >Gallery</a
            >
          </li>
          <li>
            <a
              href="/about"
              class="text-gray-500 hover:text-white transition-colors">About</a
            >
          </li>
          <li>
            <a
              href="/faq"
              class="text-gray-500 hover:text-white transition-colors">FAQ</a
            >
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="font-display font-semibold text-sm text-gray-300 mb-3">
          Legal
        </h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="/terms"
              class="text-gray-500 hover:text-white transition-colors"
              >Terms of Service</a
            >
          </li>
          <li>
            <a
              href="/privacy"
              class="text-gray-500 hover:text-white transition-colors"
              >Privacy Policy</a
            >
          </li>
        </ul>
        <p class="text-gray-600 text-xs mt-4">
          All designs are AI-generated. Each design is unique and one-of-a-kind.
        </p>
      </div>
    </div>

    <div class="border-t border-white/5 mt-8 pt-6 text-center">
      <p class="text-gray-600 text-xs">
        &copy; {currentYear} 8EyeTieDye. A Kinchito Commerce brand. All rights reserved.
      </p>
    </div>
  </div>
</footer>
