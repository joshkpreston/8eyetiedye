---
import Base from "../layouts/Base.astro";
import Generator from "../components/Generator.svelte";
---

<Base
  title="Create Your Design — 8EyeTieDye"
  description="Generate a unique AI tie-dye pattern. 3 free rolls per session. Every design is one-of-a-kind."
>
  <section class="mx-auto px-4 py-12 max-w-7xl">
    <div class="text-center mb-10">
      <h1 class="text-3xl md:text-4xl font-display font-bold mb-3">
        <span class="dye-gradient-text">Create</span> Your Design
      </h1>
      <p class="text-gray-400 max-w-lg mx-auto">
        Each spin generates a completely unique tie-dye pattern. You get 3 free
        rolls — make them count.
      </p>
    </div>

    <Generator client:load />
  </section>
</Base>
