---
import Base from "../layouts/Base.astro";
---

<Base
  title="Terms of Service — 8EyeTieDye"
  description="Terms of Service for 8EyeTieDye, an AI-generated tie-dye merchandise store."
>
  <section class="container mx-auto px-4 py-20 max-w-3xl">
    <h1
      class="text-4xl md:text-5xl font-display font-bold dye-gradient-text mb-8"
