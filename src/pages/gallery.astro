---
export const prerender = false;

import Base from "../layouts/Base.astro";
import GalleryGrid from "../components/GalleryGrid.svelte";
---

<Base
  title="Design Gallery — 8EyeTieDye"
  description="Browse all AI-generated tie-dye designs from the last 30 days."
>
  <section class="mx-auto px-2 py-12 max-w-[1600px]">
    <div class="text-center mb-8">
      <h1 class="text-3xl md:text-4xl font-display font-bold mb-3">
        <span class="dye-gradient-text">Design Gallery</span>
      </h1>
      <p class="text-gray-400 max-w-lg mx-auto">
        Every design rolled in the last 30 days. Tap any tile to view, order, or
        explore.
      </p>
    </div>

    <GalleryGrid client:load />
  </section>
</Base>
