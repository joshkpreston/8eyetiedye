---
import Base from "../layouts/Base.astro";
import ActivityTicker from "../components/ActivityTicker.svelte";
---

<Base title="8EyeTieDye — AI-Generated Tie-Dye Merch">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 dye-gradient-hero opacity-10"></div>
    <div class="relative container mx-auto px-4 py-24 md:py-36 text-center">
      <img
        src="/spider.svg"
        alt="Doobie the Spider"
        class="w-24 h-24 mx-auto mb-6"
      />
      <h1
        class="text-5xl md:text-7xl lg:text-8xl font-display font-bold dye-gradient-text mb-6"
      >
        8EyeTieDye
      </h1>
      <p class="text-xl md:text-2xl text-gray-400 mb-4 max-w-2xl mx-auto">
        AI-generated tie-dye designs. Every pattern is unique, never repeated.
      </p>
      <p class="text-lg text-gray-500 mb-10 max-w-xl mx-auto">
        Spun just for you.
      </p>
      <a
        href="/generate"
        class="inline-block px-10 py-4 bg-dye-purple hover:bg-dye-purple-dark text-white font-display font-bold text-xl rounded-2xl transition-all dye-glow hover:scale-105 active:scale-95"
      >
        Spin the Web
      </a>
    </div>
  </section>

  <!-- Activity Ticker -->
  <ActivityTicker client:load />

  <!-- How It Works -->
  <section class="bg-surface-800/50 py-20">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-center mb-16">
        How It <span class="dye-gradient-text">Works</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center p-6">
          <div
            class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-dye-purple/20 flex items-center justify-center text-3xl"
          >
            🎲
          </div>
          <h3 class="font-display font-semibold text-lg mb-2">1. Spin</h3>
          <p class="text-gray-400 text-sm">
            Hit "Spin the Web" and our AI generates a completely unique tie-dye
            pattern. Get 3 free rolls to find your perfect design.
          </p>
        </div>
        <div class="text-center p-6">
          <div
            class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-dye-pink/20 flex items-center justify-center text-3xl"
          >
            ✨
          </div>
          <h3 class="font-display font-semibold text-lg mb-2">2. Discover</h3>
          <p class="text-gray-400 text-sm">
            Watch your design reveal with a rarity tier — from Common to the
            ultra-rare Mythic (1 in 1,000). Chase the rare drops.
          </p>
        </div>
        <div class="text-center p-6">
          <div
            class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-dye-lime/20 flex items-center justify-center text-3xl"
          >
            👕
          </div>
          <h3 class="font-display font-semibold text-lg mb-2">3. Wear</h3>
          <p class="text-gray-400 text-sm">
            Love it? Buy it as a premium all-over-print tee, hoodie, or tie.
            Your one-of-a-kind design, printed and shipped.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Rarity Tiers -->
  <section class="py-20">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-center mb-4">
        Rarity <span class="dye-gradient-text">Tiers</span>
      </h2>
      <p class="text-gray-500 text-center mb-16 max-w-lg mx-auto">
        Every roll has a chance to drop something extraordinary. How lucky are
        you?
      </p>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 max-w-4xl mx-auto">
        <div
          class="p-4 rounded-xl bg-surface-700 border border-rarity-common/20 text-center"
        >
          <div class="text-rarity-common font-display font-bold text-sm mb-1">
            Common
          </div>
          <div class="text-gray-500 text-xs">70%</div>
        </div>
        <div
          class="p-4 rounded-xl bg-surface-700 border border-rarity-uncommon/20 text-center"
        >
          <div class="text-rarity-uncommon font-display font-bold text-sm mb-1">
            Uncommon
          </div>
          <div class="text-gray-500 text-xs">20%</div>
        </div>
        <div
          class="p-4 rounded-xl bg-surface-700 border border-rarity-rare/20 text-center"
        >
          <div class="text-rarity-rare font-display font-bold text-sm mb-1">
            Rare
          </div>
          <div class="text-gray-500 text-xs">8%</div>
        </div>
        <div
          class="p-4 rounded-xl bg-surface-700 border border-rarity-legendary/30 text-center"
        >
          <div
            class="text-rarity-legendary font-display font-bold text-sm mb-1"
          >
            Legendary
          </div>
          <div class="text-gray-500 text-xs">1.9%</div>
        </div>
        <div
          class="col-span-2 md:col-span-1 p-4 rounded-xl bg-surface-700 border border-rarity-mythic/30 text-center"
        >
          <div class="text-rarity-mythic font-display font-bold text-sm mb-1">
            Mythic
          </div>
          <div class="text-gray-500 text-xs">0.1%</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 relative overflow-hidden">
    <div class="absolute inset-0 dye-gradient-hero opacity-5"></div>
    <div class="relative container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">
        No Two Webs Alike
      </h2>
      <p class="text-gray-400 mb-8 max-w-lg mx-auto">
        Your design expires in 24 hours. Once it's gone, it's gone forever. Will
        you let your one-of-a-kind pattern slip away?
      </p>
      <a
        href="/generate"
        class="inline-block px-10 py-4 bg-dye-purple hover:bg-dye-purple-dark text-white font-display font-bold text-xl rounded-2xl transition-all dye-glow hover:scale-105 active:scale-95"
      >
        Spin the Web
      </a>
    </div>
  </section>
</Base>
