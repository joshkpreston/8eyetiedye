---
export const prerender = false;

import Base from "../layouts/Base.astro";
import { env } from "cloudflare:workers";
import { parseSession, requireSessionSecret } from "../lib/session";

const sessionSecret = requireSessionSecret(env.SESSION_SECRET);
const session = await parseSession(
  Astro.request.headers.get("cookie"),
  sessionSecret,
);

let designs: Record<string, unknown>[] = [];
let username = "";

if (session?.userId) {
  username = session.username || "";
  const result = await env.DB.prepare(
    `SELECT d.id, d.name, d.rarity, d.image_url, d.created_at, ud.source
     FROM user_designs ud
     JOIN designs d ON d.id = ud.design_id
     WHERE ud.user_id = ?
     ORDER BY ud.created_at DESC
     LIMIT 100`,
  )
    .bind(session.userId)
    .all();
  designs = result.results as Record<string, unknown>[];
}

const RARITY_COLORS: Record<string, string> = {
  common: "text-gray-400",
  uncommon: "text-green-400",
  rare: "text-blue-400",
  legendary: "text-amber-400",
  mythic: "text-red-400",
};

const SOURCE_LABELS: Record<string, string> = {
  purchase: "Purchased",
  mystery_pack: "Mystery Pack",
  roll: "Rolled",
};
---

<Base title="My Designs — 8EyeTieDye">
  <section class="container mx-auto px-4 py-12 max-w-5xl">
    {
      session?.userId ? (
        <>
          <div class="mb-8">
            <h1 class="text-3xl font-display font-bold mb-2">
              {username ? `${username}'s` : "My"} Designs
            </h1>
            <p class="text-gray-500">
              {designs.length > 0
                ? `${designs.length} design${designs.length !== 1 ? "s" : ""} in your collection`
                : "No designs yet — purchase a design or mystery pack to start your collection."}
            </p>
          </div>

          {designs.length > 0 ? (
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
              {designs.map((d) => (
                <a
                  href={`/design/${d.id}`}
                  class="group rounded-xl overflow-hidden border border-white/10 bg-surface-700 hover:border-white/20 transition-all hover:scale-[1.02]"
                >
                  <img
                    src={`/api/design/${d.id}/image`}
                    alt={(d.name as string) || "Design"}
                    class="w-full aspect-square object-cover"
                    loading="lazy"
                  />
                  <div class="p-3">
                    <p class="font-display font-semibold text-sm text-white truncate">
                      {d.name || "Untitled"}
                    </p>
                    <div class="flex items-center justify-between mt-1">
                      <span
                        class={`text-xs font-display font-bold ${RARITY_COLORS[d.rarity as string] || "text-gray-400"}`}
                      >
                        {(d.rarity as string).charAt(0).toUpperCase() +
                          (d.rarity as string).slice(1)}
                      </span>
                      <span class="text-[10px] text-gray-600">
                        {SOURCE_LABELS[d.source as string] || d.source}
                      </span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="text-center py-16">
              <div class="text-5xl mb-4">🎨</div>
              <p class="text-gray-500 text-lg mb-6">Your collection is empty</p>
              <div class="flex gap-4 justify-center">
                <a
                  href="/generate"
                  class="px-8 py-3 bg-purple-600 hover:bg-purple-700 text-white font-display font-semibold rounded-xl transition-all"
                >
                  Roll a Design
                </a>
                <a
                  href="/gallery"
                  class="px-8 py-3 bg-white/10 hover:bg-white/20 text-white font-display font-semibold rounded-xl transition-all"
                >
                  Browse Gallery
                </a>
              </div>
            </div>
          )}
        </>
      ) : (
        <div class="text-center py-20">
          <div class="text-5xl mb-4">🔒</div>
          <h1 class="text-3xl font-display font-bold mb-4">
            Sign in to view your designs
          </h1>
          <p class="text-gray-500 mb-6">
            Create an account to save purchased designs and mystery packs to
            your collection.
          </p>
          <a
            href="/generate"
            class="px-8 py-3 bg-purple-600 hover:bg-purple-700 text-white font-display font-semibold rounded-xl transition-all"
          >
            Start Rolling
          </a>
        </div>
      )
    }
  </section>
</Base>
