---
import Base from "../layouts/Base.astro";
---

<Base title="Something Went Wrong — 8EyeTieDye">
  <section class="container mx-auto px-4 py-24 text-center">
    <div class="max-w-lg mx-auto">
      <img src="/spider.svg" alt="" class="w-20 h-20 mx-auto mb-6 opacity-50" />
      <h1 class="text-4xl font-display font-bold mb-4">500</h1>
      <p class="text-gray-400 text-lg mb-8">
        Doobie's web got tangled. Something went wrong on our end.
      </p>
      <div class="flex gap-4 justify-center">
        <a
          href="/"
          class="px-6 py-3 bg-white/10 hover:bg-white/20 text-white font-display font-semibold rounded-xl transition-colors"
        >
          Go Home
        </a>
        <a
          href="/generate"
          class="px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white font-display font-semibold rounded-xl transition-colors"
        >
          Try Again
        </a>
      </div>
    </div>
  </section>
</Base>
