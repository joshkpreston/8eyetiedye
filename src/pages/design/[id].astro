---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import ProductList from "../../components/ProductList.svelte";
import InlineCart from "../../components/InlineCart.svelte";
import RarityBadge from "../../components/RarityBadge.svelte";
import { env } from "cloudflare:workers";

const { id } = Astro.params;

let design: Record<string, unknown> | null = null;

if (id) {
  try {
    design = await env.DB.prepare(
      "SELECT id, name, username, rarity, image_url, created_at, expires_at FROM designs WHERE id = ? AND is_public = 1",
    )
      .bind(id)
      .first();
  } catch {
    // Design not found
  }
}

const isExpired =
  design?.expires_at &&
  new Date(design.expires_at as string) < new Date();
---

<Base
  title={design ? `${design.name || "Design"} — 8EyeTieDye` : "Design Not Found — 8EyeTieDye"}
>
  <section class="mx-auto px-4 py-12 max-w-7xl">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm">
      <a href="/gallery" class="text-gray-500 hover:text-white transition-colors">
        Gallery
      </a>
      <span class="text-gray-600 mx-2">›</span>
      <span class="text-gray-300">{design?.name || "Design"}</span>
    </nav>

    {design && !isExpired ? (
      <!-- Faint design background -->
      <div
        class="fixed inset-0 z-0 pointer-events-none"
        style={`top: 4rem; background-image: url('/api/design/${design.id}/image'); background-size: cover; background-position: center; opacity: 0.04;`}
      ></div>

      <div class="relative z-10 flex flex-col lg:flex-row gap-6 lg:gap-8">
        <!-- Left: Design image -->
        <div class="flex-1 lg:max-w-[55%] space-y-4">
          <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl">
            <img
              src={`/api/design/${design.id}/image`}
              alt={design.name as string || "Tie-dye design"}
              class="w-full aspect-square object-cover"
            />
          </div>

          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <RarityBadge rarity={design.rarity as string} />
              <span class="font-display font-semibold text-white">
                {design.name}
              </span>
            </div>
            <span class="text-xs text-gray-500">
              by {design.username || "Anonymous"}
            </span>
          </div>

          <a
            href="/gallery"
            class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-medium rounded-lg transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back to Gallery
          </a>
        </div>

        <!-- Right: Products + Cart -->
        <div class="lg:w-[45%]">
          <div class="lg:sticky lg:top-20 space-y-6">
            <div>
              <h2 class="font-display font-bold text-lg">
                {design.name || "Design"}
              </h2>
              <p class="text-gray-500 text-sm">Choose products for this design</p>
            </div>

            <ProductList
              client:load
              designId={design.id as string}
              designName={design.name as string || "Untitled"}
              rarity={design.rarity as string}
            />

            <InlineCart client:load />
          </div>
        </div>
      </div>
    ) : (
      <div class="text-center py-20">
        <p class="text-gray-500 text-lg mb-4">
          {isExpired ? "This design has expired." : "Design not found."}
        </p>
        <a
          href="/gallery"
          class="inline-block px-8 py-3 bg-purple-600 hover:bg-purple-700 text-white font-display font-semibold rounded-xl transition-all"
        >
          Browse Gallery
        </a>
      </div>
    )}
  </section>
</Base>
