---
import Base from "../../layouts/Base.astro";
---

<Base title="Checkout Cancelled — 8EyeTieDye">
  <section class="container mx-auto px-4 py-20 text-center max-w-xl">
    <img src="/spider.svg" alt="Doobie" class="w-16 h-16 mx-auto mb-6" />
    <h1 class="text-3xl font-display font-bold mb-4">Checkout Cancelled</h1>
    <p class="text-gray-400 mb-8">
      No worries! Your design is still waiting for you. Remember, designs expire
      after 24 hours — don't let it slip away.
    </p>
    <div class="flex gap-4 justify-center">
      <a
        href="/generate"
        class="px-8 py-3 bg-purple-600 hover:bg-purple-700 text-white font-display font-semibold rounded-xl transition-all"
      >
        Back to Generator
      </a>
    </div>
  </section>
</Base>
