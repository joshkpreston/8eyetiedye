---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import { env } from "cloudflare:workers";

const orderId = Astro.params.id;

let order = null;
let design = null;

try {
  const orderResult = await env.DB.prepare("SELECT * FROM orders WHERE id = ?")
    .bind(orderId)
    .first();

  if (orderResult) {
    order = orderResult;
    const designResult = await env.DB.prepare(
      "SELECT * FROM designs WHERE id = ?",
    )
      .bind(order.design_id)
      .first();
    design = designResult;
  }
} catch (err) {
  console.error("Failed to fetch order:", err);
}

const statusLabels: Record<string, string> = {
  pending: "Payment Received",
  paid: "Payment Confirmed",
  processing: "In Production",
  shipped: "Shipped",
  delivered: "Delivered",
  failed: "Issue with Order",
};
---

<Base title={order ? `Order ${orderId?.slice(0, 8)}` : "Order Not Found"}>
  <section class="container mx-auto px-4 py-20 max-w-2xl">
    {
      order ? (
        <div>
          <h1 class="text-3xl font-display font-bold mb-6">
            Order #{orderId?.slice(0, 8)}
          </h1>

          <div class="bg-surface-700 rounded-2xl p-6 border border-white/10 space-y-4">
            <div class="flex justify-between items-center">
              <span class="text-gray-400">Status</span>
              <span class="font-display font-semibold text-purple-400">
                {statusLabels[order.status as string] || order.status}
              </span>
            </div>

            <div class="flex justify-between items-center">
              <span class="text-gray-400">Product</span>
              <span>{order.product_type}</span>
            </div>

            <div class="flex justify-between items-center">
              <span class="text-gray-400">Size</span>
              <span>{order.variant_id}</span>
            </div>

            {order.amount_cents && (
              <div class="flex justify-between items-center">
                <span class="text-gray-400">Amount Paid</span>
                <span class="font-semibold">
                  ${((order.amount_cents as number) / 100).toFixed(2)}
                </span>
              </div>
            )}

            {order.tracking_url && (
              <div class="flex justify-between items-center">
                <span class="text-gray-400">Tracking</span>
                <a
                  href={order.tracking_url as string}
                  target="_blank"
                  rel="noopener"
                  class="text-purple-400 hover:underline"
                >
                  {order.tracking_number || "Track Package"}
                </a>
              </div>
            )}

            {design && (
              <div class="pt-4 border-t border-white/10">
                <p class="text-gray-400 text-sm mb-2">Design</p>
                <div class="w-32 h-32 rounded-xl overflow-hidden bg-surface-600">
                  <img
                    src={`/api/design/${design.id}/image`}
                    alt="Your tie-dye design"
                    class="w-full h-full object-cover"
                  />
                </div>
              </div>
            )}
          </div>
        </div>
      ) : (
        <div class="text-center">
          <h1 class="text-3xl font-display font-bold mb-4">Order Not Found</h1>
          <p class="text-gray-400 mb-8">
            We couldn't find an order with that ID.
          </p>
          <a
            href="/"
            class="px-8 py-3 bg-purple-600 hover:bg-purple-700 text-white font-display font-semibold rounded-xl transition-all"
          >
            Home
          </a>
        </div>
      )
    }
  </section>
</Base>
