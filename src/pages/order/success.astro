---
export const prerender = false;

import Base from "../../layouts/Base.astro";
import { env } from "cloudflare:workers";

const sessionId = Astro.url.searchParams.get("session_id");

let order: Record<string, unknown> | null = null;
let design: Record<string, unknown> | null = null;

if (sessionId) {
  try {
    const orderResult = await env.DB.prepare(
      "SELECT * FROM orders WHERE stripe_session_id = ?",
    )
      .bind(sessionId)
      .first();

    if (orderResult) {
      order = orderResult as Record<string, unknown>;
      const designResult = await env.DB.prepare(
        "SELECT * FROM designs WHERE id = ?",
      )
        .bind(order.design_id)
        .first();
      if (designResult) {
        design = designResult as Record<string, unknown>;
      }
    }
  } catch (err) {
    console.error("Failed to fetch order details:", err);
  }
}
---

<Base title="Order Confirmed — 8EyeTieDye">
  <section class="container mx-auto px-4 py-20 text-center max-w-2xl">
    <div class="text-6xl mb-6">🎉</div>
    <h1 class="text-4xl font-display font-bold mb-4">Order Confirmed!</h1>
    <p class="text-gray-400 text-lg mb-8">
      Your one-of-a-kind tie-dye design is being printed. You'll receive an
      email with tracking information once it ships.
    </p>

    {order && (
      <div class="bg-surface-700 rounded-2xl p-6 mb-8 border border-white/10">
        <div class="flex items-start gap-6 mb-6">
          {design && (
            <div class="w-24 h-24 rounded-xl overflow-hidden bg-surface-600 shrink-0">
              <img
                src={`/api/design/${design.id}/image`}
                alt="Your tie-dye design"
                class="w-full h-full object-cover"
              />
            </div>
          )}
          <div class="text-left">
            <p class="text-sm text-gray-500 mb-1">Order</p>
            <p class="font-display font-semibold text-lg">
              #{(order.id as string).slice(0, 8)}
            </p>
            <p class="text-gray-400 mt-1">{order.product_type}</p>
          </div>
        </div>
      </div>
    )}

    <div
      class="bg-surface-700 rounded-2xl p-6 mb-8 text-left border border-white/10"
    >
      <h2 class="font-display font-semibold text-lg mb-4">
        What happens next?
      </h2>
      <ol class="space-y-3 text-gray-400">
        <li class="flex gap-3">
          <span class="text-purple-400 font-bold">1.</span>
          Your design is sent to our print partner for production
        </li>
        <li class="flex gap-3">
          <span class="text-purple-400 font-bold">2.</span>
          Sublimation printing infuses the design into the fabric
        </li>
        <li class="flex gap-3">
          <span class="text-purple-400 font-bold">3.</span>
          Quality check and packaging
        </li>
        <li class="flex gap-3">
          <span class="text-purple-400 font-bold">4.</span>
          Ships to you within 3-5 business days
        </li>
      </ol>
    </div>

    <div class="flex gap-4 justify-center">
      {order && (
        <a
          href={`/order/${order.id}`}
          class="px-8 py-3 bg-purple-600 hover:bg-purple-700 text-white font-display font-semibold rounded-xl transition-all"
        >
          Track Order
        </a>
      )}
      <a
        href="/generate"
        class="px-8 py-3 bg-purple-600 hover:bg-purple-700 text-white font-display font-semibold rounded-xl transition-all"
      >
        Spin Again
      </a>
      <a
        href="/"
        class="px-8 py-3 bg-white/10 hover:bg-white/20 text-white font-display font-semibold rounded-xl transition-all"
      >
        Home
      </a>
    </div>
  </section>
</Base>
