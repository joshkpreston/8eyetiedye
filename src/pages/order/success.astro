---
import Base from "../../layouts/Base.astro";
---

<Base title="Order Confirmed — 8EyeTieDye">
  <section class="container mx-auto px-4 py-20 text-center max-w-2xl">
    <div class="text-6xl mb-6">🎉</div>
    <h1 class="text-4xl font-display font-bold mb-4">Order Confirmed!</h1>
    <p class="text-gray-400 text-lg mb-8">
      Your one-of-a-kind tie-dye design is being printed. You'll receive an
      email with tracking information once it ships.
    </p>

    <div
      class="bg-surface-700 rounded-2xl p-6 mb-8 text-left border border-white/10"
    >
      <h2 class="font-display font-semibold text-lg mb-4">
        What happens next?
      </h2>
      <ol class="space-y-3 text-gray-400">
        <li class="flex gap-3">
          <span class="text-purple-400 font-bold">1.</span>
          Your design is sent to our print partner for production
        </li>
        <li class="flex gap-3">
          <span class="text-purple-400 font-bold">2.</span>
          Sublimation printing infuses the design into the fabric
        </li>
        <li class="flex gap-3">
          <span class="text-purple-400 font-bold">3.</span>
          Quality check and packaging
        </li>
        <li class="flex gap-3">
          <span class="text-purple-400 font-bold">4.</span>
          Ships to you within 3-5 business days
        </li>
      </ol>
    </div>

    <div class="flex gap-4 justify-center">
      <a
        href="/generate"
        class="px-8 py-3 bg-purple-600 hover:bg-purple-700 text-white font-display font-semibold rounded-xl transition-all"
      >
        Spin Again
      </a>
      <a
        href="/"
        class="px-8 py-3 bg-white/10 hover:bg-white/20 text-white font-display font-semibold rounded-xl transition-all"
      >
        Home
      </a>
    </div>
  </section>
</Base>
