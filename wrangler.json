{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "8eyetiedye",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2025-03-10",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "8eyetiedye-db",
      "database_id": "530aa326-074c-48c7-afcc-bd2ed6506071"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SESSIONS",
      "id": "800c0473d5cb419fa85397bb185696b6"
    }
  ],
  "r2_buckets": [
    {
      "binding": "DESIGNS",
      "bucket_name": "8eyetiedye-designs"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "ENVIRONMENT": "production",
    "PUBLIC_TURNSTILE_SITE_KEY": "0x4AAAAAACtWcxyuvvP_rV0I"
  },
  "triggers": {
    "crons": ["0 3 * * *"]
  },
  "env": {
    "staging": {
      "name": "8eyetiedye-staging",
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "8eyetiedye-db-staging",
          "database_id": "aab22788-9e9e-404c-b43b-50ed25ddb0b4"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "SESSIONS",
          "id": "5bcb074a9f694c4d9244f9ef7aaa9c50"
        }
      ],
      "r2_buckets": [
        {
          "binding": "DESIGNS",
          "bucket_name": "8eyetiedye-designs"
        }
      ],
      "ai": {
        "binding": "AI"
      },
      "vars": {
        "ENVIRONMENT": "staging",
        "PUBLIC_TURNSTILE_SITE_KEY": "0x4AAAAAACtWcxyuvvP_rV0I"
      }
    }
  }
}
